# Nyiur Nanggroe — Production Environment Variables
# Copy these keys into Vercel dashboard environment settings

# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-production-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-production-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-production-service-role-key

# ============================================
# AI PROVIDERS
# ============================================
OPENAI_API_KEY=your-production-openai-key
GEMINI_API_KEY=your-production-gemini-key

# ============================================
# PAYMENT GATEWAY (Midtrans Production)
# ============================================
MIDTRANS_SERVER_KEY=your-production-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-production-midtrans-client-key
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your-production-midtrans-client-key
MIDTRANS_IS_PRODUCTION=true

# ============================================
# APP CONFIG
# ============================================
NEXT_PUBLIC_APP_URL=https://nyiurnanggroe.id
NEXT_PUBLIC_APP_NAME="Nyiur Nanggroe"
NEXT_PUBLIC_DEFAULT_LOCALE=id
NODE_ENV=production
